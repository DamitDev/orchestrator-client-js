{
  "name": "orchestrator-client",
  "version": "5.6.0",
  "description": "TypeScript/JavaScript client for the DAMIT AIOps Orchestrator REST API and Socket.IO realtime events",
  "license": "Apache-2.0",
  "author": "Damit Informatika",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DamitDev/orchestrator-client-js.git"
  },
  "bugs": {
    "url": "https://github.com/DamitDev/orchestrator-client-js/issues"
  },
  "homepage": "https://github.com/DamitDev/orchestrator-client-js#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">= 18"
  },
  "packageManager": "pnpm@10.33.2",
  "peerDependencies": {
    "socket.io-client": "^4.x"
  },
  "peerDependenciesMeta": {
    "socket.io-client": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src/",
    "lint:fix": "biome check --write --unsafe src/",
    "format": "biome format --write src/",
    "format:check": "biome format src/",
    "prepublishOnly": "pnpm build",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^25.9.0",
    "socket.io-client": "^4.8.3",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.5"
  }
}
